# MongoDB Connection (add your own URI)
MONGODB_URI=your_mongodb_connection_string_here

# Paystack Configuration
# Get these from your Paystack dashboard: https://dashboard.paystack.co/#/settings/developer
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# Site URL (required for payment callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
